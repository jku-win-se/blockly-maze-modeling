package blocky_game;

import javafx.animation.KeyFrame;
import javafx.animation.Timeline;
import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.canvas.Canvas;
import javafx.scene.canvas.GraphicsContext;
import javafx.scene.control.*;
import javafx.scene.image.Image;
import javafx.scene.layout.BorderPane;
import javafx.scene.layout.HBox;
import javafx.scene.layout.VBox;
import javafx.scene.paint.Color;
import javafx.stage.Stage;
import javafx.util.Duration;

import java.io.File;
import java.net.MalformedURLException;
import java.util.ArrayList;
import java.util.List;

import blocky.*; // Your generated EMF code

public class BlockyUI extends Application {

    private GameEngine engine;
    private Level currentLevel;
    
    private Canvas canvas;
    private Label statusLabel;
    private ListView<BlockItem> astListView; 
    private Timeline currentTimeline;
    private Button runButton;
    private CheckBox asChildBox;
    private CheckBox intoElseBox;
    
    // Assets
    private Image pegmanImg;
    private Image markerImg;
    private Image roadImg;
    
    private static final int CELL_SIZE = 50;
    private static final int MAP_WIDTH = 8;
    private static final int MAP_HEIGHT = 8;

    // Helper class to map ListView items back to EMF Blocks
    private static class BlockItem {
        Block block;
        String label;
        int indent;
        
        BlockItem(Block block, String label, int indent) {
            this.block = block;
            this.label = label;
            this.indent = indent;
        }
        
        @Override
        public String toString() {
            return "    ".repeat(indent) + "• " + label;
        }
    }

    @Override
    public void start(Stage primaryStage) {
        engine = new GameEngine();
        engine.initializeGame();
        currentLevel = engine.getCurrentLevel();

        loadAssets();

        BorderPane root = new BorderPane();
        root.setPadding(new Insets(20));
        root.setStyle("-fx-background-color: white;");
        
        // --- Left Column: Visualization ---
        VBox leftSide = new VBox(20);
        leftSide.setAlignment(Pos.TOP_CENTER);
        leftSide.setPrefWidth(MAP_WIDTH * CELL_SIZE + 40);
        
        canvas = new Canvas(MAP_WIDTH * CELL_SIZE, MAP_HEIGHT * CELL_SIZE);
        
        canvas.setOnMouseClicked(e -> {
            int x = (int) (e.getX() / CELL_SIZE);
            int y = (int) (e.getY() / CELL_SIZE);
            if (x >= 0 && x < MAP_WIDTH && y >= 0 && y < MAP_HEIGHT) {
                engine.cycleCellType(x, y);
                drawMap(canvas.getGraphicsContext2D());
                drawInitialDoll(canvas.getGraphicsContext2D());
            }
        });

        runButton = new Button("▶ RUN PROGRAM");
        runButton.setId("runButton");
        runButton.setPrefWidth(220);
        runButton.setOnAction(e -> {
            if (currentTimeline != null && currentTimeline.getStatus() == Timeline.Status.RUNNING) {
                stopAnimation();
            } else if (runButton.getText().contains("RESET")) {
                stopAnimation();
            } else {
                engine.simulateUserProgram(); 
                playAnimation();
            }
        });

        leftSide.getChildren().addAll(canvas, runButton);
        root.setLeft(leftSide);

        // --- Center Area: Toolbox ---
        VBox toolbox = new VBox(10);
        toolbox.setPrefWidth(160);
        toolbox.setId("toolbox");
        toolbox.setPadding(new Insets(10));

        Label toolboxLabel = new Label("Add Blocks");
        toolboxLabel.getStyleClass().add("area-title");
        toolbox.getChildren().add(toolboxLabel);

        asChildBox = new CheckBox("Add inside");
        asChildBox.setTooltip(new Tooltip("Add as first child of selected Repeat/If block"));
        intoElseBox = new CheckBox("Into ELSE");
        intoElseBox.setTooltip(new Tooltip("Add into else branch of selected If block"));

        addToolboxButton(toolbox, "move forward", "#A55B80", e -> { engine.addMoveForwardBlock(getSelectedBlock(), asChildBox.isSelected(), intoElseBox.isSelected()); refreshASTView(); });
        addToolboxButton(toolbox, "turn left ↺", "#A55B80", e -> { engine.addTurnBlock(TurnDirection.LEFT, getSelectedBlock(), asChildBox.isSelected(), intoElseBox.isSelected()); refreshASTView(); });
        addToolboxButton(toolbox, "turn right ↻", "#A55B80", e -> { engine.addTurnBlock(TurnDirection.RIGHT, getSelectedBlock(), asChildBox.isSelected(), intoElseBox.isSelected()); refreshASTView(); });
        addToolboxButton(toolbox, "repeat until 🏁", "#5BA55B", e -> { engine.addRepeatUntilGoalBlock(getSelectedBlock(), asChildBox.isSelected(), intoElseBox.isSelected()); refreshASTView(); });
        addToolboxButton(toolbox, "if path ahead", "#5B80A5", e -> { engine.addIfPathBlock(SensorDirection.AHEAD, getSelectedBlock(), asChildBox.isSelected(), intoElseBox.isSelected()); refreshASTView(); });
        addToolboxButton(toolbox, "if path left", "#5B80A5", e -> { engine.addIfPathBlock(SensorDirection.LEFT, getSelectedBlock(), asChildBox.isSelected(), intoElseBox.isSelected()); refreshASTView(); });
        addToolboxButton(toolbox, "if path right", "#5B80A5", e -> { engine.addIfPathBlock(SensorDirection.RIGHT, getSelectedBlock(), asChildBox.isSelected(), intoElseBox.isSelected()); refreshASTView(); });

        toolbox.getChildren().addAll(new Separator(), asChildBox, intoElseBox);

        // --- Right Area: Workspace ---
        VBox workspace = new VBox(0);
        workspace.setId("workspace");
        HBox.setHgrow(workspace, javafx.scene.layout.Priority.ALWAYS);
        workspace.setPadding(new Insets(10));

        Label workspaceLabel = new Label("Program Workspace (Select target block)");
        workspaceLabel.getStyleClass().add("area-title");
        workspaceLabel.setStyle("-fx-font-size: 14px;");
        
        astListView = new ListView<>();
        VBox.setVgrow(astListView, javafx.scene.layout.Priority.ALWAYS);
        
        Button btnClear = new Button("Clear All Blocks");
        btnClear.setId("clearButton");
        btnClear.setMaxWidth(Double.MAX_VALUE);
        btnClear.setOnAction(e -> { engine.clearProgram(); refreshASTView(); });

        workspace.getChildren().addAll(workspaceLabel, astListView, btnClear);
        
        HBox editorArea = new HBox(toolbox, workspace);
        editorArea.setPadding(new Insets(0, 0, 0, 20));
        root.setCenter(editorArea);

        // --- Bottom Area ---
        statusLabel = new Label("Ready to start!");
        statusLabel.setPadding(new Insets(10));
        root.setBottom(statusLabel);
        BorderPane.setAlignment(statusLabel, Pos.CENTER);

        // Initial Draw
        refreshASTView();
        drawMap(canvas.getGraphicsContext2D());
        drawInitialDoll(canvas.getGraphicsContext2D());

        Scene scene = new Scene(root, 1150, 750);
        try {
            File cssFile = new File("src/blocky_game/style.css");
            scene.getStylesheets().add(cssFile.toURI().toURL().toExternalForm());
        } catch (MalformedURLException e) { e.printStackTrace(); }
        
        primaryStage.setTitle("Blockly Games : Maze (Nested Blocks)");
        primaryStage.setScene(scene);
        primaryStage.show();
    }

    private Block getSelectedBlock() {
        BlockItem selected = astListView.getSelectionModel().getSelectedItem();
        return (selected != null) ? selected.block : null;
    }

    private void addToolboxButton(VBox container, String text, String color, javafx.event.EventHandler<javafx.event.ActionEvent> handler) {
        Button btn = new Button(text);
        btn.setStyle("-fx-background-color: " + color + ";");
        btn.getStyleClass().add("block-btn");
        btn.setMaxWidth(Double.MAX_VALUE);
        btn.setOnAction(handler);
        container.getChildren().add(btn);
    }

    private void loadAssets() {
        try {
            pegmanImg = new Image(new File("src/blocky_game/assets/pegman.png").toURI().toURL().toExternalForm());
            markerImg = new Image(new File("src/blocky_game/assets/marker.png").toURI().toURL().toExternalForm());
            roadImg = new Image(new File("src/blocky_game/assets/road.png").toURI().toURL().toExternalForm());
        } catch (Exception e) { System.err.println("Asset loading failed: " + e.getMessage()); }
    }

    private void refreshASTView() {
        astListView.getItems().clear();
        appendBlocksToListView(currentLevel.getSolution(), 0);
        if (astListView.getItems().isEmpty()) astListView.getItems().add(new BlockItem(null, "(Empty Workspace)", 0));
    }

    private void appendBlocksToListView(Block first, int indent) {
        Block current = first;
        while (current != null) {
            if (current instanceof MoveForward) {
                astListView.getItems().add(new BlockItem(current, "move forward", indent));
            } else if (current instanceof Turn) {
                Turn t = (Turn) current;
                astListView.getItems().add(new BlockItem(current, "turn " + (t.getDirection() == TurnDirection.LEFT ? "left ↺" : "right ↻"), indent));
            } else if (current instanceof RepeatUntilGoal) {
                astListView.getItems().add(new BlockItem(current, "repeat until 🏁 {", indent));
                appendBlocksToListView(((RepeatUntilGoal)current).getBody(), indent + 1);
                astListView.getItems().add(new BlockItem(current, "}", indent));
            } else if (current instanceof IfStatement) {
                IfStatement i = (IfStatement) current;
                astListView.getItems().add(new BlockItem(current, "if path " + i.getCondition().toString().toLowerCase() + " {", indent));
                appendBlocksToListView(i.getThenBranch(), indent + 1);
                if (i.getElseBranch() != null) {
                    astListView.getItems().add(new BlockItem(current, "} else {", indent));
                    appendBlocksToListView(i.getElseBranch(), indent + 1);
                }
                astListView.getItems().add(new BlockItem(current, "}", indent));
            }
            current = current.getNext();
        }
    }

    private void drawMap(GraphicsContext gc) {
        gc.setFill(Color.web("#F0F0F0"));
        gc.fillRect(0, 0, canvas.getWidth(), canvas.getHeight());
        int i = 0;
        for (Cell cell : currentLevel.getMap().getCells()) {
            int x = (i % MAP_WIDTH) * CELL_SIZE;
            int y = (i / MAP_WIDTH) * CELL_SIZE;
            if (cell.getType() != CellType.WALL) {
                if (roadImg != null) gc.drawImage(roadImg, x, y, CELL_SIZE, CELL_SIZE);
                else { gc.setFill(Color.web("#FFFFE0")); gc.fillRect(x, y, CELL_SIZE, CELL_SIZE); }
            } else {
                gc.setFill(Color.web("#D0D0D0")); gc.fillRect(x, y, CELL_SIZE, CELL_SIZE);
            }
            if (cell.getType() == CellType.GOAL && markerImg != null) gc.drawImage(markerImg, x + 5, y - 5, CELL_SIZE - 10, CELL_SIZE);
            gc.setStroke(Color.web("#DDDDDD")); gc.setLineWidth(0.5); gc.strokeRect(x, y, CELL_SIZE, CELL_SIZE);
            i++;
        }
    }

    private void drawInitialDoll(GraphicsContext gc) {
        Cell startCell = null;
        for (Cell c : currentLevel.getMap().getCells()) if (c.getType() == CellType.START) startCell = c;
        if (startCell != null) {
            GameState mockState = BlockyFactory.eINSTANCE.createGameState();
            mockState.setPosition(startCell);
            mockState.setOrientation(currentLevel.getStartOrientation());
            drawDoll(gc, mockState);
        }
    }

    private void drawDoll(GraphicsContext gc, GameState state) {
        int index = currentLevel.getMap().getCells().indexOf(state.getPosition());
        int x = (index % MAP_WIDTH) * CELL_SIZE;
        int y = (index / MAP_WIDTH) * CELL_SIZE;
        if (pegmanImg != null) {
            double sw = pegmanImg.getWidth() / 4.0;
            double sh = pegmanImg.getHeight();
            int col = 0;
            switch (state.getOrientation()) {
                case SOUTH: col = 0; break; case NORTH: col = 1; break; case EAST: col = 2; break; case WEST: col = 3; break;
            }
            gc.drawImage(pegmanImg, col * sw, 0, sw, sh, x + 5, y + 5, CELL_SIZE - 10, CELL_SIZE - 10);
        } else { gc.setFill(Color.YELLOW); gc.fillOval(x + 10, y + 10, CELL_SIZE - 20, CELL_SIZE - 20); }
    }

    private void stopAnimation() {
        if (currentTimeline != null) currentTimeline.stop();
        runButton.setText("▶ RUN PROGRAM");
        drawMap(canvas.getGraphicsContext2D());
        drawInitialDoll(canvas.getGraphicsContext2D());
        statusLabel.setText("Ready to start!");
    }

    private void playAnimation() {
        if (currentTimeline != null) currentTimeline.stop();
        if (currentLevel.getTraces().isEmpty()) return;
        runButton.setText("↺ RESET");
        ExecutionTrace trace = currentLevel.getTraces().get(0);
        currentTimeline = new Timeline();
        int frameIndex = 0;
        for (GameState state : trace.getStates()) {
            final boolean isLast = (frameIndex == trace.getStates().size() - 1);
            KeyFrame kf = new KeyFrame(Duration.seconds(frameIndex * 0.4), e -> {
                drawMap(canvas.getGraphicsContext2D());
                drawDoll(canvas.getGraphicsContext2D(), state);
                statusLabel.setText("Step: " + state.getStep() + " | " + state.getStatus());
                if (isLast) {
                    if (state.getStatus() == GameStatus.WON) statusLabel.setText("🎉 CONGRATULATIONS! GOAL REACHED!");
                    else if (state.getStatus() == GameStatus.CRASHED) statusLabel.setText("💥 CRASHED! TRY AGAIN.");
                }
            });
            currentTimeline.getKeyFrames().add(kf);
            frameIndex++;
        }
        currentTimeline.play();
    }

    public static void main(String[] args) { launch(args); }
}