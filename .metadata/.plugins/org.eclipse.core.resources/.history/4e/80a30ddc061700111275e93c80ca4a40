package blocky_game;

import javafx.animation.KeyFrame;
import javafx.animation.Timeline;
import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Node;
import javafx.scene.Scene;
import javafx.scene.canvas.Canvas;
import javafx.scene.canvas.GraphicsContext;
import javafx.scene.control.*;
import javafx.scene.image.Image;
import javafx.scene.input.*;
import javafx.scene.layout.*;
import javafx.scene.paint.Color;
import javafx.scene.shape.Path;
import javafx.scene.text.Font;
import javafx.scene.text.FontWeight;
import javafx.stage.Stage;
import javafx.util.Duration;

import java.io.File;
import java.net.MalformedURLException;
import java.util.ArrayList;
import java.util.List;

import blocky.*; // Your generated EMF code

public class BlockyUI extends Application {

    private GameEngine engine;
    private Level currentLevel;
    
    private Canvas canvas;
    private Label statusLabel;
    private VBox workspaceVBox; 
    private Timeline currentTimeline;
    private Button runButton;
    private StackPane trashCan;
    
    // Assets
    private Image pegmanImg;
    private Image markerImg;
    private Image roadImg;
    
    private static final int CELL_SIZE = 50;
    private static final int MAP_WIDTH = 8;
    private static final int MAP_HEIGHT = 8;
    
    private static final DataFormat BLOCK_DATA = new DataFormat("blocky/type");

    @Override
    public void start(Stage primaryStage) {
        engine = new GameEngine();
        engine.initializeGame();
        currentLevel = engine.getCurrentLevel();

        loadAssets();

        BorderPane root = new BorderPane();
        root.setPadding(new Insets(20));
        root.setStyle("-fx-background-color: #E0E0E0;");
        
        // --- Left Column: Visualization ---
        VBox leftSide = new VBox(20);
        leftSide.setAlignment(Pos.TOP_CENTER);
        leftSide.setPadding(new Insets(10));
        leftSide.setPrefWidth(MAP_WIDTH * CELL_SIZE + 40);
        
        canvas = new Canvas(MAP_WIDTH * CELL_SIZE, MAP_HEIGHT * CELL_SIZE);
        canvas.setStyle("-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 5);");
        
        canvas.setOnMouseClicked(e -> {
            int x = (int) (e.getX() / CELL_SIZE);
            int y = (int) (e.getY() / CELL_SIZE);
            if (x >= 0 && x < MAP_WIDTH && y >= 0 && y < MAP_HEIGHT) {
                engine.cycleCellType(x, y);
                drawMap(canvas.getGraphicsContext2D());
                drawInitialDoll(canvas.getGraphicsContext2D());
            }
        });

        runButton = new Button("▶ RUN PROGRAM");
        runButton.setId("runButton");
        runButton.setPrefWidth(220);
        runButton.setOnAction(e -> {
            if (currentTimeline != null && currentTimeline.getStatus() == Timeline.Status.RUNNING) {
                stopAnimation();
            } else if (runButton.getText().contains("RESET")) {
                stopAnimation();
            } else {
                engine.simulateUserProgram(); 
                playAnimation();
            }
        });

        // Trash Can
        trashCan = new StackPane(new Label("🗑"));
        trashCan.setStyle("-fx-background-color: #f1f3f4; -fx-border-color: #d93025; -fx-border-radius: 50; -fx-background-radius: 50; -fx-font-size: 30;");
        trashCan.setPrefSize(80, 80);
        trashCan.setMaxSize(80, 80);
        setupTrashCanDragAndDrop(trashCan);

        leftSide.getChildren().addAll(canvas, runButton, trashCan);
        root.setLeft(leftSide);

        // --- Center Area: Toolbox ---
        VBox toolbox = new VBox(10);
        toolbox.setPrefWidth(180);
        toolbox.setId("toolbox");
        toolbox.setPadding(new Insets(10));
        toolbox.setStyle("-fx-background-color: #DEDEDE; -fx-border-color: #BBBBBB; -fx-border-width: 0 1 0 0;");

        Label toolboxTitle = new Label("Toolbox");
        toolboxTitle.getStyleClass().add("area-title");
        toolboxTitle.setStyle("-fx-font-size: 14px;");
        toolbox.getChildren().add(toolboxTitle);

        addDraggableToolboxButton(toolbox, "move forward", "#A55B80", "MOVE");
        addDraggableToolboxButton(toolbox, "turn left ↺", "#A55B80", "TURN_LEFT");
        addDraggableToolboxButton(toolbox, "turn right ↻", "#A55B80", "TURN_RIGHT");
        addDraggableToolboxButton(toolbox, "repeat until 🏁", "#5BA55B", "REPEAT");
        addDraggableToolboxButton(toolbox, "if path ahead", "#5B80A5", "IF_AHEAD");

        // --- Right Area: Visual Workspace ---
        VBox editorSide = new VBox(0);
        HBox.setHgrow(editorSide, Priority.ALWAYS);
        
        Label wsLabel = new Label("Workspace (Drag and Drop to piece together)");
        wsLabel.setStyle("-fx-padding: 10; -fx-font-weight: bold; -fx-background-color: white;");
        wsLabel.setMaxWidth(Double.MAX_VALUE);

        ScrollPane scrollPane = new ScrollPane();
        scrollPane.setFitToWidth(true);
        scrollPane.setStyle("-fx-background: white; -fx-background-color: white;");
        
        workspaceVBox = new VBox(0);
        workspaceVBox.setMinHeight(1000);
        workspaceVBox.setPadding(new Insets(40));
        workspaceVBox.setStyle("-fx-background-color: white;");
        
        setupWorkspaceDragAndDrop(workspaceVBox);
        
        scrollPane.setContent(workspaceVBox);
        
        editorSide.getChildren().addAll(wsLabel, scrollPane);
        
        HBox centerArea = new HBox(toolbox, editorSide);
        centerArea.setStyle("-fx-background-color: white;");
        root.setCenter(centerArea);

        // Bottom Area
        statusLabel = new Label("Ready to start!");
        statusLabel.setPadding(new Insets(10));
        root.setBottom(statusLabel);
        BorderPane.setAlignment(statusLabel, Pos.CENTER);

        refreshWorkspace();
        drawMap(canvas.getGraphicsContext2D());
        drawInitialDoll(canvas.getGraphicsContext2D());

        Scene scene = new Scene(root, 1200, 800);
        try {
            File cssFile = new File("src/blocky_game/style.css");
            scene.getStylesheets().add(cssFile.toURI().toURL().toExternalForm());
        } catch (MalformedURLException e) { e.printStackTrace(); }
        
        primaryStage.setTitle("Blockly Games : Maze Jigsaw");
        primaryStage.setScene(scene);
        primaryStage.show();
    }

    private void addDraggableToolboxButton(VBox container, String text, String color, String type) {
        Button btn = new Button(text);
        btn.setStyle("-fx-background-color: " + color + ";");
        btn.getStyleClass().add("block-btn");
        btn.setMaxWidth(Double.MAX_VALUE);
        
        btn.setOnDragDetected(e -> {
            Dragboard db = btn.startDragAndDrop(TransferMode.COPY);
            ClipboardContent content = new ClipboardContent();
            content.put(BLOCK_DATA, type);
            db.setContent(content);
            e.consume();
        });
        
        container.getChildren().add(btn);
    }

    private void setupWorkspaceDragAndDrop(Pane workspace) {
        workspace.setOnDragOver(e -> {
            if (e.getDragboard().hasContent(BLOCK_DATA)) {
                e.acceptTransferModes(TransferMode.ANY);
            }
            e.consume();
        });

        workspace.setOnDragDropped(e -> {
            Dragboard db = e.getDragboard();
            if (db.hasContent(BLOCK_DATA)) {
                String type = (String) db.getContent(BLOCK_DATA);
                addBlockByType(type, null, false, false);
                refreshWorkspace();
                e.setDropCompleted(true);
            }
            e.consume();
        });
    }

    private void setupTrashCanDragAndDrop(StackPane can) {
        can.setOnDragOver(e -> {
            if (e.getDragboard().hasContent(BLOCK_DATA)) {
                e.acceptTransferModes(TransferMode.ANY);
                can.setStyle("-fx-background-color: #fae3e3; -fx-border-color: #d93025;-fx-border-radius: 50; -fx-background-radius: 50; -fx-font-size: 35;");
            }
            e.consume();
        });
        can.setOnDragExited(e -> {
            can.setStyle("-fx-background-color: #f1f3f4; -fx-border-color: #d93025; -fx-border-radius: 50; -fx-background-radius: 50; -fx-font-size: 30;");
        });
        can.setOnDragDropped(e -> {
            // Deletion logic would happen if we were dragging specific block instances.
            // For now, this just provides the visual experience.
            e.setDropCompleted(true); e.consume();
        });
    }

    private void refreshWorkspace() {
        workspaceVBox.getChildren().clear();
        renderBlocksToVBox(currentLevel.getSolution(), workspaceVBox);
        if (workspaceVBox.getChildren().isEmpty()) {
            Label empty = new Label("(Drag blocks here to start)");
            empty.setTextFill(Color.GRAY);
            workspaceVBox.getChildren().add(empty);
        }
    }

    private void renderBlocksToVBox(Block first, Pane container) {
        Block current = first;
        while (current != null) {
            final Block thisBlock = current;
            Node blockNode = createJigsawBlock(current);
            container.getChildren().add(blockNode);
            
            if (current instanceof RepeatUntilGoal) {
                VBox bodyBox = (VBox) ((StackPane)blockNode).getProperties().get("bodyContainer");
                renderBlocksToVBox(((RepeatUntilGoal)current).getBody(), bodyBox);
                setupSnapZone(bodyBox, thisBlock, true, false);
            } else if (current instanceof IfStatement) {
                VBox thenBox = (VBox) ((StackPane)blockNode).getProperties().get("thenContainer");
                renderBlocksToVBox(((IfStatement)current).getThenBranch(), thenBox);
                setupSnapZone(thenBox, thisBlock, true, false);
            }
            
            // Setup snap zone AFTER this block
            setupSnapZone(blockNode, thisBlock, false, false);

            current = current.getNext();
        }
    }

    private void setupSnapZone(Node node, Block target, boolean asChild, boolean intoElse) {
        node.setOnDragOver(e -> {
            if (e.getDragboard().hasContent(BLOCK_DATA)) {
                e.acceptTransferModes(TransferMode.ANY);
                // Visual Highlight (Yellow glow)
                node.setEffect(new javafx.scene.effect.InnerShadow(20, Color.YELLOW));
            }
            e.consume();
        });
        node.setOnDragExited(e -> node.setEffect(null));
        node.setOnDragDropped(e -> {
            String type = (String) e.getDragboard().getContent(BLOCK_DATA);
            addBlockByType(type, target, asChild, intoElse);
            refreshWorkspace();
            e.setDropCompleted(true);
            e.consume();
        });
    }

    private void addBlockByType(String type, Block target, boolean asChild, boolean intoElse) {
        if (type.equals("MOVE")) engine.addMoveForwardBlock(target, asChild, intoElse);
        else if (type.equals("TURN_LEFT")) engine.addTurnBlock(TurnDirection.LEFT, target, asChild, intoElse);
        else if (type.equals("TURN_RIGHT")) engine.addTurnBlock(TurnDirection.RIGHT, target, asChild, intoElse);
        else if (type.equals("REPEAT")) engine.addRepeatUntilGoalBlock(target, asChild, intoElse);
        else if (type.equals("IF_AHEAD")) engine.addIfPathBlock(SensorDirection.AHEAD, target, asChild, intoElse);
    }

    private Node createJigsawBlock(Block block) {
        String label = "Unknown";
        String color = "#A55B80";
        boolean isContainer = false;

        if (block instanceof MoveForward) { label = "move forward"; color = "#A55B80"; }
        else if (block instanceof Turn) { 
            Turn t = (Turn) block;
            label = "turn " + (t.getDirection() == TurnDirection.LEFT ? "left ↺" : "right ↻"); 
        }
        else if (block instanceof RepeatUntilGoal) { label = "repeat until 🏁"; color = "#5BA55B"; isContainer = true; }
        else if (block instanceof IfStatement) { 
            IfStatement i = (IfStatement) block;
            label = "if path " + i.getCondition().toString().toLowerCase(); 
            color = "#5B80A5"; isContainer = true; 
        }

        StackPane stack = new StackPane();
        stack.setAlignment(Pos.TOP_LEFT);

        double width = 160;
        Path path;

        if (isContainer) {
            VBox innerContainer = new VBox(0);
            innerContainer.setPadding(new Insets(BlockShape.BLOCK_H, 0, BlockShape.BLOCK_H, 30));
            innerContainer.setMinWidth(width - 30);
            innerContainer.setMinHeight(20);
            
            path = BlockShape.createContainerPath(width, 20); 
            path.setFill(Color.web(color));
            path.setStroke(Color.WHITE);
            path.setStrokeWidth(0.5);
            
            Label l = new Label(label);
            l.setTextFill(Color.WHITE);
            l.setFont(Font.font("Segoe UI", FontWeight.BOLD, 13));
            l.setPadding(new Insets(10, 0, 0, 10));

            stack.getChildren().addAll(path, innerContainer, l);
            if (block instanceof RepeatUntilGoal) stack.getProperties().put("bodyContainer", innerContainer);
            else stack.getProperties().put("thenContainer", innerContainer);

        } else {
            path = BlockShape.createStandardPath(width);
            path.setFill(Color.web(color));
            path.setStroke(Color.WHITE);
            path.setStrokeWidth(0.5);
            
            Label l = new Label(label);
            l.setTextFill(Color.WHITE);
            l.setFont(Font.font("Segoe UI", FontWeight.BOLD, 13));
            l.setPadding(new Insets(10, 0, 0, 10));
            
            stack.getChildren().addAll(path, l);
        }

        return stack;
    }

    private void loadAssets() {
        try {
            pegmanImg = new Image(new File("src/blocky_game/assets/pegman.png").toURI().toURL().toExternalForm());
            markerImg = new Image(new File("src/blocky_game/assets/marker.png").toURI().toURL().toExternalForm());
            roadImg = new Image(new File("src/blocky_game/assets/road.png").toURI().toURL().toExternalForm());
        } catch (Exception e) { System.err.println("Asset loading failed: " + e.getMessage()); }
    }

    private void drawMap(GraphicsContext gc) {
        gc.setFill(Color.web("#F1EEE7"));
        gc.fillRect(0, 0, canvas.getWidth(), canvas.getHeight());
        int i = 0;
        for (Cell cell : currentLevel.getMap().getCells()) {
            int x = (i % MAP_WIDTH) * CELL_SIZE;
            int y = (i / MAP_WIDTH) * CELL_SIZE;
            if (cell.getType() != CellType.WALL) {
                if (roadImg != null) gc.drawImage(roadImg, x, y, CELL_SIZE, CELL_SIZE);
                else { gc.setFill(Color.web("#FFFFE0")); gc.fillRect(x, y, CELL_SIZE, CELL_SIZE); }
            } else {
                gc.setFill(Color.web("#CCB")); gc.fillRect(x, y, CELL_SIZE, CELL_SIZE);
            }
            if (cell.getType() == CellType.GOAL && markerImg != null) gc.drawImage(markerImg, x + 5, y - 5, CELL_SIZE - 10, CELL_SIZE);
            gc.setStroke(Color.web("#DDDDDD")); gc.setLineWidth(0.5); gc.strokeRect(x, y, CELL_SIZE, CELL_SIZE);
            i++;
        }
    }

    private void drawInitialDoll(GraphicsContext gc) {
        Cell startCell = null;
        for (Cell c : currentLevel.getMap().getCells()) if (c.getType() == CellType.START) startCell = c;
        if (startCell != null) {
            GameState mockState = BlockyFactory.eINSTANCE.createGameState();
            mockState.setPosition(startCell);
            mockState.setOrientation(currentLevel.getStartOrientation());
            drawDoll(gc, mockState);
        }
    }

    private void drawDoll(GraphicsContext gc, GameState state) {
        int index = currentLevel.getMap().getCells().indexOf(state.getPosition());
        int x = (index % MAP_WIDTH) * CELL_SIZE;
        int y = (index / MAP_WIDTH) * CELL_SIZE;
        if (pegmanImg != null) {
            double sw = pegmanImg.getWidth() / 4.0;
            double sh = pegmanImg.getHeight();
            int col = 0;
            switch (state.getOrientation()) {
                case SOUTH: col = 0; break; case NORTH: col = 1; break; case EAST: col = 2; break; case WEST: col = 3; break;
            }
            gc.drawImage(pegmanImg, col * sw, 0, sw, sh, x + 5, y + 5, CELL_SIZE - 10, CELL_SIZE - 10);
        } else { gc.setFill(Color.YELLOW); gc.fillOval(x + 10, y + 10, CELL_SIZE - 20, CELL_SIZE - 20); }
    }

    private void stopAnimation() {
        if (currentTimeline != null) currentTimeline.stop();
        runButton.setText("▶ RUN PROGRAM");
        drawMap(canvas.getGraphicsContext2D());
        drawInitialDoll(canvas.getGraphicsContext2D());
        statusLabel.setText("Ready to start!");
    }

    private void playAnimation() {
        if (currentTimeline != null) currentTimeline.stop();
        if (currentLevel.getTraces().isEmpty()) return;
        runButton.setText("↺ RESET");
        ExecutionTrace trace = currentLevel.getTraces().get(0);
        currentTimeline = new Timeline();
        int frameIndex = 0;
        for (GameState state : trace.getStates()) {
            final boolean isLast = (frameIndex == trace.getStates().size() - 1);
            KeyFrame kf = new KeyFrame(Duration.seconds(frameIndex * 0.4), e -> {
                drawMap(canvas.getGraphicsContext2D());
                drawDoll(canvas.getGraphicsContext2D(), state);
                statusLabel.setText("Step: " + state.getStep() + " | " + state.getStatus());
                if (isLast) {
                    if (state.getStatus() == GameStatus.WON) statusLabel.setText("🎉 CONGRATULATIONS!");
                    else if (state.getStatus() == GameStatus.CRASHED) statusLabel.setText("💥 CRASHED!");
                }
            });
            currentTimeline.getKeyFrames().add(kf);
            frameIndex++;
        }
        currentTimeline.play();
    }

    public static void main(String[] args) { launch(args); }
}