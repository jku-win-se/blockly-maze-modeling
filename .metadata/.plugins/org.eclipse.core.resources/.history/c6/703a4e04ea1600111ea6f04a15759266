package blocky_game;

import javafx.animation.KeyFrame;
import javafx.animation.Timeline;
import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.canvas.Canvas;
import javafx.scene.canvas.GraphicsContext;
import javafx.scene.control.Button;
import javafx.scene.control.Label;
import javafx.scene.control.ListView;
import javafx.scene.layout.BorderPane;
import javafx.scene.layout.HBox;
import javafx.scene.layout.VBox;
import javafx.scene.paint.Color;
import javafx.scene.text.Font;
import javafx.scene.text.FontWeight;
import javafx.stage.Stage;
import javafx.util.Duration;

import blocky.*; // Your generated EMF code

public class BlockyUI extends Application {

    private GameEngine engine;
    private Level currentLevel;
    
    private Canvas canvas;
    private Label statusLabel;
    private ListView<String> astListView; // Shows the current Blocks
    private Timeline currentTimeline;
    
    private static final int CELL_SIZE = 60;
    private static final int MAP_WIDTH = 8;
    private static final int MAP_HEIGHT = 8;

    @Override
    public void start(Stage primaryStage) {
        engine = new GameEngine();
        engine.initializeGame();
        currentLevel = engine.getCurrentLevel();

        BorderPane root = new BorderPane();
        
        // 1. Center Canvas (The Map)
        canvas = new Canvas(MAP_WIDTH * CELL_SIZE, MAP_HEIGHT * CELL_SIZE);
        root.setCenter(canvas);
        
        // Handle Map Editing Clicks
        canvas.setOnMouseClicked(e -> {
            int x = (int) (e.getX() / CELL_SIZE);
            int y = (int) (e.getY() / CELL_SIZE);
            engine.cycleCellType(x, y); // Cycle the cell type in EMF
            drawMap(canvas.getGraphicsContext2D());
            drawInitialDoll(canvas.getGraphicsContext2D()); // Redraw doll at Start
        });

        // 2. Right Side Panel (The AST / Block Editor)
        VBox rightPanel = new VBox(10);
        rightPanel.setPadding(new Insets(10));
        rightPanel.setPrefWidth(200);
        rightPanel.setStyle("-fx-background-color: #f4f4f4;");

        Label editorLabel = new Label("Program Editor");
        editorLabel.setFont(Font.font("Arial", FontWeight.BOLD, 14));
        
        Button btnMove = new Button("Add: Move Forward");
        btnMove.setMaxWidth(Double.MAX_VALUE);
        btnMove.setOnAction(e -> { engine.addMoveForwardBlock(); refreshASTView(); });
        
        Button btnTurnLeft = new Button("Add: Turn Left");
        btnTurnLeft.setMaxWidth(Double.MAX_VALUE);
        btnTurnLeft.setOnAction(e -> { engine.addTurnBlock(TurnDirection.LEFT); refreshASTView(); });
        
        Button btnTurnRight = new Button("Add: Turn Right");
        btnTurnRight.setMaxWidth(Double.MAX_VALUE);
        btnTurnRight.setOnAction(e -> { engine.addTurnBlock(TurnDirection.RIGHT); refreshASTView(); });

        Button btnClear = new Button("Clear Program");
        btnClear.setMaxWidth(Double.MAX_VALUE);
        btnClear.setTextFill(Color.RED);
        btnClear.setOnAction(e -> { engine.clearProgram(); refreshASTView(); });

        astListView = new ListView<>();
        
        rightPanel.getChildren().addAll(editorLabel, btnMove, btnTurnLeft, btnTurnRight, btnClear, astListView);
        root.setRight(rightPanel);

        // 3. Bottom Panel (Simulation Controls)
        statusLabel = new Label("Status: WAITING");
        statusLabel.setFont(new Font("Arial", 18));
        
        Button playButton = new Button("▶ Play Program");
        playButton.setStyle("-fx-font-weight: bold; -fx-base: #a4e5a0;");
        playButton.setOnAction(e -> {
            // Recalculate the ExecutionTrace LIVE based on current map/blocks
            engine.simulateUserProgram(); 
            playAnimation();
        });
        
        HBox bottomPanel = new HBox(20, playButton, statusLabel);
        bottomPanel.setAlignment(Pos.CENTER);
        bottomPanel.setPadding(new Insets(15));
        root.setBottom(bottomPanel);

        // Initial Draw
        refreshASTView();
        drawMap(canvas.getGraphicsContext2D());
        drawInitialDoll(canvas.getGraphicsContext2D());

        Scene scene = new Scene(root);
        primaryStage.setTitle("Blockly Maze - Live EMF Editor");
        primaryStage.setScene(scene);
        primaryStage.show();
    }

    private void refreshASTView() {
        astListView.getItems().clear();
        Block current = currentLevel.getSolution();
        int step = 1;
        while (current != null) {
            if (current instanceof MoveForward) {
                astListView.getItems().add(step + ". Move Forward");
            } else if (current instanceof Turn) {
                Turn t = (Turn) current;
                astListView.getItems().add(step + ". Turn " + t.getDirection());
            }
            current = current.getNext();
            step++;
        }
        if (astListView.getItems().isEmpty()) {
            astListView.getItems().add("(Empty Program)");
        }
    }

    private void drawMap(GraphicsContext gc) {
        gc.setFill(Color.LIGHTGRAY);
        gc.fillRect(0, 0, canvas.getWidth(), canvas.getHeight());

        int i = 0;
        for (Cell cell : currentLevel.getMap().getCells()) {
            int x = i % MAP_WIDTH;
            int y = i / MAP_WIDTH;
            
            switch (cell.getType()) {
                case EMPTY: gc.setFill(Color.WHITE); break;
                case WALL:  gc.setFill(Color.DARKGRAY); break;
                case START: gc.setFill(Color.LIGHTGREEN); break;
                case GOAL:  gc.setFill(Color.GOLD); break;
            }
            
            gc.fillRect(x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE);
            gc.setStroke(Color.GRAY);
            gc.strokeRect(x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE);
            i++;
        }
    }

    // Draws the doll sitting at the START node before the animation plays
    private void drawInitialDoll(GraphicsContext gc) {
        Cell startCell = null;
        for (Cell c : currentLevel.getMap().getCells()) {
            if (c.getType() == CellType.START) startCell = c;
        }
        if (startCell != null) {
            GameState mockState = BlockyFactory.eINSTANCE.createGameState();
            mockState.setPosition(startCell);
            mockState.setOrientation(currentLevel.getStartOrientation());
            drawDoll(gc, mockState);
        }
    }

    private void drawDoll(GraphicsContext gc, GameState state) {
        int index = currentLevel.getMap().getCells().indexOf(state.getPosition());
        int x = index % MAP_WIDTH;
        int y = index / MAP_WIDTH;

        double padding = 10;
        gc.setFill(Color.DODGERBLUE);
        gc.fillOval(x * CELL_SIZE + padding, y * CELL_SIZE + padding, 
                    CELL_SIZE - padding * 2, CELL_SIZE - padding * 2);

        gc.setStroke(Color.BLACK);
        gc.setLineWidth(3);
        
        double centerX = x * CELL_SIZE + CELL_SIZE / 2.0;
        double centerY = y * CELL_SIZE + CELL_SIZE / 2.0;
        double endX = centerX;
        double endY = centerY;
        
        int lineLength = 15;
        switch (state.getOrientation()) {
            case NORTH: endY -= lineLength; break;
            case SOUTH: endY += lineLength; break;
            case EAST:  endX += lineLength; break;
            case WEST:  endX -= lineLength; break;
        }
        gc.strokeLine(centerX, centerY, endX, endY);
    }

    private void playAnimation() {
        if (currentTimeline != null) currentTimeline.stop();
        
        if (currentLevel.getTraces().isEmpty()) return;
        ExecutionTrace trace = currentLevel.getTraces().get(0);
        
        currentTimeline = new Timeline();
        int frameIndex = 0;

        for (GameState state : trace.getStates()) {
            KeyFrame kf = new KeyFrame(Duration.seconds(frameIndex * 0.8), e -> {
                drawMap(canvas.getGraphicsContext2D());
                drawDoll(canvas.getGraphicsContext2D(), state);
                
                statusLabel.setText("Step: " + state.getStep() + " | Status: " + state.getStatus());
                if (state.getStatus() == GameStatus.WON) {
                    statusLabel.setTextFill(Color.GREEN);
                } else if (state.getStatus() == GameStatus.CRASHED) {
                    statusLabel.setTextFill(Color.RED);
                } else {
                    statusLabel.setTextFill(Color.BLACK);
                }
            });
            currentTimeline.getKeyFrames().add(kf);
            frameIndex++;
        }
        
        currentTimeline.play();
    }

    public static void main(String