package blocky_game;

import javafx.animation.KeyFrame;
import javafx.animation.Timeline;
import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.canvas.Canvas;
import javafx.scene.canvas.GraphicsContext;
import javafx.scene.control.Button;
import javafx.scene.control.Label;
import javafx.scene.layout.BorderPane;
import javafx.scene.layout.HBox;
import javafx.scene.paint.Color;
import javafx.scene.text.Font;
import javafx.stage.Stage;
import javafx.util.Duration;

import blocky.*; // Your generated EMF code

public class BlockyUI extends Application {

    private GameEngine engine;
    private Level currentLevel;
    
    private Canvas canvas;
    private Label statusLabel;
    
    private static final int CELL_SIZE = 60; // 60 pixels per cell
    private static final int MAP_WIDTH = 8;
    private static final int MAP_HEIGHT = 8;

    @Override
    public void start(Stage primaryStage) {
        // 1. Initialize the EMF Backend Game Engine
        engine = new GameEngine();
        engine.initializeGame();
        engine.simulateUserProgram(); // Generates the execution trace
        currentLevel = engine.getCurrentLevel();

        // 2. Setup the JavaFX UI Elements
        BorderPane root = new BorderPane();
        
        canvas = new Canvas(MAP_WIDTH * CELL_SIZE, MAP_HEIGHT * CELL_SIZE);
        root.setCenter(canvas);
        
        statusLabel = new Label("Status: WAITING");
        statusLabel.setFont(new Font("Arial", 18));
        
        Button playButton = new Button("Play Execution Trace");
        playButton.setOnAction(e -> playAnimation());
        
        HBox bottomPanel = new HBox(20, playButton, statusLabel);
        bottomPanel.setAlignment(Pos.CENTER);
        bottomPanel.setPadding(new Insets(15));
        root.setBottom(bottomPanel);

        // 3. Draw the initial static map
        drawMap(canvas.getGraphicsContext2D());

        Scene scene = new Scene(root);
        primaryStage.setTitle("Blockly Maze Live EMF Viewer");
        primaryStage.setScene(scene);
        primaryStage.setResizable(false);
        primaryStage.show();
    }

    private void drawMap(GraphicsContext gc) {
        // Clear background
        gc.setFill(Color.LIGHTGRAY);
        gc.fillRect(0, 0, canvas.getWidth(), canvas.getHeight());

        int i = 0;
        // In GameEngine, we added cells row by row, so we can calculate X and Y from the index
        for (Cell cell : currentLevel.getMap().getCells()) {
            int x = i % MAP_WIDTH;
            int y = i / MAP_WIDTH;
            
            // Determine Cell Color based on CellType Enum
            switch (cell.getType()) {
                case EMPTY: gc.setFill(Color.WHITE); break;
                case WALL:  gc.setFill(Color.DARKGRAY); break;
                case START: gc.setFill(Color.LIGHTGREEN); break;
                case GOAL:  gc.setFill(Color.GOLD); break;
            }
            
            // Draw the cell square
            gc.fillRect(x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE);
            gc.setStroke(Color.GRAY);
            gc.strokeRect(x * CELL_SIZE, y * CELL_SIZE, CELL_SIZE, CELL_SIZE);
            i++;
        }
    }

    private void drawDoll(GraphicsContext gc, GameState state) {
        // 1. Find where the doll is (Calculate X and Y of its current Cell)
        int index = currentLevel.getMap().getCells().indexOf(state.getPosition());
        int x = index % MAP_WIDTH;
        int y = index / MAP_WIDTH;

        // 2. Draw the Doll (A Blue Circle)
        double padding = 10;
        gc.setFill(Color.DODGERBLUE);
        gc.fillOval(x * CELL_SIZE + padding, y * CELL_SIZE + padding, 
                    CELL_SIZE - padding * 2, CELL_SIZE - padding * 2);

        // 3. Draw a line to indicate Orientation (Facing Direction)
        gc.setStroke(Color.BLACK);
        gc.setLineWidth(3);
        
        double centerX = x * CELL_SIZE + CELL_SIZE / 2.0;
        double centerY = y * CELL_SIZE + CELL_SIZE / 2.0;
        double endX = centerX;
        double endY = centerY;
        
        int lineLength = 15;
        switch (state.getOrientation()) {
            case NORTH: endY -= lineLength; break;
            case SOUTH: endY += lineLength; break;
            case EAST:  endX += lineLength; break;
            case WEST:  endX -= lineLength; break;
        }
        gc.strokeLine(centerX, centerY, endX, endY);
    }

    private void playAnimation() {
        // Grab the trace we generated in the backend
        ExecutionTrace trace = currentLevel.getTraces().get(0);
        
        Timeline timeline = new Timeline();
        int frameIndex = 0;

        // For every state in history, schedule a frame to draw it!
        for (GameState state : trace.getStates()) {
            KeyFrame kf = new KeyFrame(Duration.seconds(frameIndex * 0.8), e -> {
                // Redraw the base map
                drawMap(canvas.getGraphicsContext2D());
                
                // Draw the doll on top
                drawDoll(canvas.getGraphicsContext2D(), state);
                
                // Update text
                statusLabel.setText("Step: " + state.getStep() + " | Status: " + state.getStatus());
                
                if (state.getStatus() == GameStatus.WON) {
                    statusLabel.setTextFill(Color.GREEN);
                } else if (state.getStatus() == GameStatus.CRASHED) {
                    statusLabel.setTextFill(Color.RED);
                } else {
                    statusLabel.setTextFill(Color.BLACK);
                }
            });
            
            timeline.getKeyFrames().add(kf);
            frameIndex++;
        }
        
        timeline.play();
    }

    public static void main(String[] args) {
        launch(args);
    }
}