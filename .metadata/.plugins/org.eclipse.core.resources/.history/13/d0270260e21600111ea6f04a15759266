package blocky_game;

import org.eclipse.emf.common.util.URI;
import org.eclipse.emf.ecore.resource.Resource;
import org.eclipse.emf.ecore.resource.ResourceSet;
import org.eclipse.emf.ecore.resource.impl.ResourceSetImpl;
import org.eclipse.emf.ecore.xmi.impl.XMIResourceFactoryImpl;

import blocky.*; // Imports your generated EMF Code

public class GameEngine {

    private Level currentLevel;
    private Resource resource;
    private Cell startCell;

    public void initializeGame() {
        // 1. Initialize EMF
        BlockyPackage.eINSTANCE.eClass();
        Resource.Factory.Registry.INSTANCE.getExtensionToFactoryMap().put("xmi", new XMIResourceFactoryImpl());

        // 2. Setup File Resource
        ResourceSet resSet = new ResourceSetImpl();
        resource = resSet.createResource(URI.createFileURI("level1_state.xmi"));

        // 3. Create the Level
        currentLevel = BlockyFactory.eINSTANCE.createLevel();
        currentLevel.setId(1);
        currentLevel.setTitle("Blockly Maze - Level 1");
        currentLevel.setStartOrientation(Direction.EAST);

        // 4. Generate the Map
        generateLevel1Map();

        // 5. Save initial state
        resource.getContents().add(currentLevel);
        saveModel();
        
        System.out.println("Backend initialized. Map generated and saved to XMI.");
    }

    private void generateLevel1Map() {
        GridMap map = BlockyFactory.eINSTANCE.createGridMap();
        map.setWidth(8);
        map.setHeight(8);
        currentLevel.setMap(map);

        // 2D Array to temporarily hold cells so we can link them easily
        Cell[][] grid = new Cell[8][8];

        // Create the 8x8 cells
        for (int y = 0; y < 8; y++) {
            for (int x = 0; x < 8; x++) {
                Cell cell = BlockyFactory.eINSTANCE.createCell();
                cell.setType(CellType.EMPTY);
                grid[x][y] = cell;
                map.getCells().add(cell); // Add to containment reference
            }
        }

        // Link neighbors (Graph pointers)
        for (int y = 0; y < 8; y++) {
            for (int x = 0; x < 8; x++) {
                Cell cell = grid[x][y];
                if (y > 0) cell.setTop(grid[x][y - 1]);
                if (y < 7) cell.setBottom(grid[x][y + 1]);
                if (x > 0) cell.setLeft(grid[x - 1][y]);
                if (x < 7) cell.setRight(grid[x + 1][y]);
            }
        }

        // Customize Level 1 (A straight line from Left to Right)
        // Let's make the path on row index 4. Everything else is a WALL.
        for (int y = 0; y < 8; y++) {
            for (int x = 0; x < 8; x++) {
                if (y != 4) {
                    grid[x][y].setType(CellType.WALL);
                }
            }
        }

        // Set Start and Goal (Row 4, Col 2 to Col 6)
        startCell = grid[2][4];
        startCell.setType(CellType.START);
        
        Cell goalCell = grid[6][4];
        goalCell.setType(CellType.GOAL);
    }

    public void saveModel() {
        try {
            resource.save(null);
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    public static void main(String[] args) {
        GameEngine engine = new GameEngine();
        engine.initializeGame();
        
        // Next, we will mock an AST (The blocks the user dragged in)
        // and run the execution trace!
        engine.simulateUserProgram();
    }
}
