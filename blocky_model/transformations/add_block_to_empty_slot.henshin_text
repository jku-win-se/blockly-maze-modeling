// =============================================================================
// Delete any block from anywhere (reparent successor when block has next)
// =============================================================================

rule DeleteBlockFromSolutionWhenLast () {
	graph {
		node game : blocky.Game
		node level : blocky.Level
		delete node block : blocky.Block
		forbid node nextBlock : blocky.Block
		edges [(game->level:levels), (forbid block->nextBlock:next), (delete level->block:solution)]
	}
}

rule DeleteBlockFromSolutionWhenHasNext () {
	graph {
		node game : blocky.Game
		node level : blocky.Level
		delete node block : blocky.Block
		node rest : blocky.Block
		edges [(game->level:levels), (create level->rest:solution), (delete level->block:solution), (delete block->rest:next)]
	}
}

rule DeleteBlockFromNextWhenLast () {
	graph {
		node parent : blocky.Block
		delete node block : blocky.Block
		forbid node nextBlock : blocky.Block
		edges [(forbid block->nextBlock:next), (delete parent->block:next)]
	}
}

rule DeleteBlockFromNextWhenHasNext () {
	graph {
		node parent : blocky.Block
		delete node block : blocky.Block
		node rest : blocky.Block
		edges [(create parent->rest:next), (delete parent->block:next), (delete block->rest:next)]
	}
}

rule DeleteBlockFromThenBranchWhenLast () {
	graph {
		node ifStmt : blocky.IfStatement
		delete node block : blocky.Block
		forbid node nextBlock : blocky.Block
		edges [(forbid block->nextBlock:next), (delete ifStmt->block:thenBranch)]
	}
}

rule DeleteBlockFromThenBranchWhenHasNext () {
	graph {
		node ifStmt : blocky.IfStatement
		delete node block : blocky.Block
		node rest : blocky.Block
		edges [(create ifStmt->rest:thenBranch), (delete ifStmt->block:thenBranch), (delete block->rest:next)]
	}
}

rule DeleteBlockFromElseBranchWhenLast () {
	graph {
		node ifStmt : blocky.IfStatement
		delete node block : blocky.Block
		forbid node nextBlock : blocky.Block
		edges [(forbid block->nextBlock:next), (delete ifStmt->block:elseBranch)]
	}
}

rule DeleteBlockFromElseBranchWhenHasNext () {
	graph {
		node ifStmt : blocky.IfStatement
		delete node block : blocky.Block
		node rest : blocky.Block
		edges [(create ifStmt->rest:elseBranch), (delete ifStmt->block:elseBranch), (delete block->rest:next)]
	}
}

rule DeleteBlockFromBodyWhenLast () {
	graph {
		node loop : blocky.RepeatUntilGoal
		delete node block : blocky.Block
		forbid node nextBlock : blocky.Block
		edges [(forbid block->nextBlock:next), (delete loop->block:body)]
	}
}

rule DeleteBlockFromBodyWhenHasNext () {
	graph {
		node loop : blocky.RepeatUntilGoal
		delete node block : blocky.Block
		node rest : blocky.Block
		edges [(create loop->rest:body), (delete loop->block:body), (delete block->rest:next)]
	}
}
