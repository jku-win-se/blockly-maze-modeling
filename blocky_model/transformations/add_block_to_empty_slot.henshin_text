ePackageImport blocky

// =============================================================================
// Add any fittable block to any empty slot (next, body, thenBranch, elseBranch)
// =============================================================================

rule AddMoveForwardToSolution (){
	graph {
		node game : blocky.Game
		node level : blocky.Level
		edges [(game->level:levels)]
		forbid node block : blocky.Block
		edges [(forbid level->block:solution)]
		create node newBlock : blocky.MoveForward
		edges [(create level->newBlock:solution)]
	}
}
rule AddTurnLeftToSolution (){
	graph {
		node game : blocky.Game
		node level : blocky.Level
		edges [(game->level:levels)]
		forbid node block : blocky.Block
		edges [(forbid level->block:solution)]
		create node newBlock : blocky.Turn { direction = 0 }
		edges [(create level->newBlock:solution)]
	}
}
rule AddTurnRightToSolution (){
	graph {
		node game : blocky.Game
		node level : blocky.Level
		edges [(game->level:levels)]
		forbid node block : blocky.Block
		edges [(forbid level->block:solution)]
		create node newBlock : blocky.Turn { direction = 1 }
		edges [(create level->newBlock:solution)]
	}
}
rule AddIfAheadToSolution (){
	graph {
		node game : blocky.Game
		node level : blocky.Level
		edges [(game->level:levels)]
		forbid node block : blocky.Block
		edges [(forbid level->block:solution)]
		create node newBlock : blocky.IfStatement { condition = 0 }
		edges [(create level->newBlock:solution)]
		create node thenBlock : blocky.MoveForward
		edges [(create newBlock->thenBlock:thenBranch)]
	}
}
rule AddIfLeftToSolution (){
	graph {
		node game : blocky.Game
		node level : blocky.Level
		edges [(game->level:levels)]
		forbid node block : blocky.Block
		edges [(forbid level->block:solution)]
		create node newBlock : blocky.IfStatement { condition = 1 }
		edges [(create level->newBlock:solution)]
		create node thenBlock : blocky.MoveForward
		edges [(create newBlock->thenBlock:thenBranch)]
	}
}
rule AddIfRightToSolution (){
	graph {
		node game : blocky.Game
		node level : blocky.Level
		edges [(game->level:levels)]
		forbid node block : blocky.Block
		edges [(forbid level->block:solution)]
		create node newBlock : blocky.IfStatement { condition = 2 }
		edges [(create level->newBlock:solution)]
		create node thenBlock : blocky.MoveForward
		edges [(create newBlock->thenBlock:thenBranch)]
	}
}
rule AddRepeatUntilGoalToSolution (){
	graph {
		node game : blocky.Game
		node level : blocky.Level
		edges [(game->level:levels)]
		forbid node block : blocky.Block
		edges [(forbid level->block:solution)]
		create node newBlock : blocky.RepeatUntilGoal
		edges [(create level->newBlock:solution)]
		create node bodyBlock : blocky.MoveForward
		edges [(create newBlock->bodyBlock:body)]
	}
}
rule AddMoveForwardToNext (){
	graph {
		node parent : blocky.Block
		forbid node block : blocky.Block
		edges [(forbid parent->block:next)]
		create node newBlock : blocky.MoveForward
		edges [(create parent->newBlock:next)]
	}
}
rule AddTurnLeftToNext (){
	graph {
		node parent : blocky.Block
		forbid node block : blocky.Block
		edges [(forbid parent->block:next)]
		create node newBlock : blocky.Turn { direction = 0 }
		edges [(create parent->newBlock:next)]
